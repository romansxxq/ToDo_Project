@{
    ViewData["Title"] = "Dashboard";
    ViewData["BodyClass"] = "home";
}

<div class="space-y-6">
    @if (TempData["AlertMessage"] is string alertMessage)
    {
        <script>
            window.addEventListener("DOMContentLoaded", () => {
                window.alert("@alertMessage");
            });
        </script>
    }

    <div class="text-xs text-muted-foreground">Workspace / Dashboard</div>
    <div>
        <h1 class="text-2xl font-semibold tracking-tight text-foreground">Dashboard</h1>
        <p class="text-sm text-muted-foreground"><span id="task-count">0</span> tasks found</p>
    </div>

    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border shadow-sm">
            <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Total Tasks</div>
            <div class="text-3xl font-semibold text-card-foreground mt-3" id="analytics-total">0</div>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border shadow-sm">
            <div class="text-xs font-semibold uppercase tracking-wider text-status-completed">Completed</div>
            <div class="text-3xl font-semibold text-card-foreground mt-3" id="analytics-completed">0</div>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border shadow-sm">
            <div class="text-xs font-semibold uppercase tracking-wider text-status-pending">Pending</div>
            <div class="text-3xl font-semibold text-card-foreground mt-3" id="analytics-pending">0</div>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border shadow-sm">
            <div class="text-xs font-semibold uppercase tracking-wider text-status-overdue">Overdue</div>
            <div class="text-3xl font-semibold text-card-foreground mt-3" id="analytics-overdue">0</div>
        </div>
    </section>

    <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-3">
            <div class="flex items-center gap-1 bg-card p-1 rounded-lg border border-border">
                <button class="tab active px-3 py-1.5 text-sm font-medium rounded-md text-foreground" type="button" data-filter="all">All</button>
                <button class="tab px-3 py-1.5 text-sm font-medium rounded-md text-muted-foreground hover:text-foreground" type="button" data-filter="pending">Pending</button>
                <button class="tab px-3 py-1.5 text-sm font-medium rounded-md text-muted-foreground hover:text-foreground" type="button" data-filter="completed">Completed</button>
                <button class="tab px-3 py-1.5 text-sm font-medium rounded-md text-muted-foreground hover:text-foreground" type="button" data-filter="overdue">Overdue</button>
            </div>
            <select id="priority-filter" class="px-3 py-2 text-sm border border-border rounded-lg bg-card text-foreground focus:ring-2 focus:ring-ring outline-none transition-all">
                <option value="all" selected>All Priorities</option>
                <option value="low">Low</option>
                <option value="medium">Medium</option>
                <option value="high">High</option>
            </select>
        </div>

        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
            </svg>
            <input id="task-search" type="text" placeholder="Search tasks..."
                   class="w-64 pl-9 pr-4 py-2 text-sm border border-border rounded-lg bg-card text-foreground placeholder:text-muted-foreground focus:ring-2 focus:ring-ring focus:border-transparent outline-none transition-all" />
        </div>
    </div>

    <div class="bg-card rounded-xl border border-border shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-secondary/50 border-b border-border">
                    <tr>
                        <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">Task</th>
                        <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden md:table-cell">Due Date</th>
                        <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden sm:table-cell">Priority</th>
                        <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden sm:table-cell">Status</th>
                        <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border" id="task-list"></tbody>
            </table>
        </div>
    </div>

    <div class="space-y-3">
        <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Completed</div>
        <div class="bg-card rounded-xl border border-border shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-secondary/50 border-b border-border">
                        <tr>
                            <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">Task</th>
                            <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden md:table-cell">Due Date</th>
                            <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden sm:table-cell">Priority</th>
                            <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden sm:table-cell">Status</th>
                            <th class="px-6 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border" id="completed-list"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <label for="global-chat-id" class="text-sm text-muted-foreground">Telegram Chat ID</label>
        <input id="global-chat-id" class="w-56 px-3 py-2 border border-border rounded-lg bg-card text-foreground text-sm" type="number" placeholder="Telegram Chat ID" />
    </div>
    <aside class="test-panel hidden" id="test-panel" aria-hidden="true"></aside>
</div>

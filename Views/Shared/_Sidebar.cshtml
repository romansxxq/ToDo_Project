@{
    var currentPath = Context.Request.Path.ToString().ToLower();
    var navItems = new[] {
        new { Href = "/", Label = "Dashboard" },
        new { Href = "/Tasks/Create", Label = "Create Task" }
    };
}
<aside class="w-64 border-r border-border bg-card hidden md:flex flex-col">
    <div class="p-6 flex items-center gap-2">
        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
        </svg>
        <h1 class="text-lg font-semibold tracking-tight text-foreground">ToDoApp</h1>
    </div>
    <nav class="flex-1 px-4 space-y-1">
        @foreach (var item in navItems)
        {
            var isActive = currentPath == item.Href.ToLower() ||
                          (item.Href != "/" && currentPath.StartsWith(item.Href.ToLower()));
            var classes = isActive
                ? "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md bg-secondary text-primary transition-colors"
                : "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-secondary/50 hover:text-foreground transition-colors";
            <a href="@item.Href" class="@classes">
                <span class="h-4 w-4">●</span>
                @item.Label
            </a>
        }
    </nav>
    <div class="p-4 border-t border-border">
        <p class="text-xs text-muted-foreground">ToDoApp v1.0</p>
    </div>
</aside>

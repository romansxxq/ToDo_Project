<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ToDoApp</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        border: 'hsl(220 15% 88%)',
                        input: 'hsl(220 15% 82%)',
                        ring: 'hsl(220 50% 45%)',
                        background: 'hsl(220 20% 97%)',
                        foreground: 'hsl(220 30% 15%)',
                        primary: { DEFAULT: 'hsl(220 50% 45%)', foreground: 'hsl(0 0% 100%)' },
                        secondary: { DEFAULT: 'hsl(220 15% 94%)', foreground: 'hsl(220 30% 15%)' },
                        destructive: { DEFAULT: 'hsl(0 72% 51%)', foreground: 'hsl(0 0% 100%)' },
                        muted: { DEFAULT: 'hsl(220 15% 94%)', foreground: 'hsl(220 10% 46%)' },
                        card: { DEFAULT: 'hsl(0 0% 100%)', foreground: 'hsl(220 30% 15%)' },
                        'status-completed': 'hsl(152 60% 40%)',
                        'status-pending': 'hsl(38 92% 50%)',
                        'status-overdue': 'hsl(0 72% 51%)'
                    }
                }
            }
        };
    </script>
    <style>
        body { font-feature-settings: "cv11", "ss01"; letter-spacing: -0.01em; }
        h1, h2, h3, h4, h5, h6 { letter-spacing: -0.03em; text-wrap: balance; }
        .tabular-nums { font-variant-numeric: tabular-nums; }
    </style>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ToDo_Project.styles.css" asp-append-version="true" />
</head>
<body class="bg-background text-foreground antialiased">
    <div class="flex min-h-screen">
        @await Html.PartialAsync("_Sidebar")
        <main class="flex-1 flex flex-col min-w-0">
            @await Html.PartialAsync("_Header")
            <div class="p-6 lg:p-8 max-w-7xl mx-auto w-full flex-1">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

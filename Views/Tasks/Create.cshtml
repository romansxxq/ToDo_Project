@model ToDo_Project.Models.ViewModels.TaskFormViewModel

@{
    ViewData["Title"] = "Create Task";
    ViewData["BodyClass"] = "tasks";
}

<div class="space-y-6">
    <div class="text-xs text-muted-foreground">Workspace / Create Task</div>
    <div class="text-center">
        <h1 class="text-2xl font-semibold tracking-tight text-foreground">Create New Task</h1>
        <p class="text-sm text-muted-foreground">Fill in the details below to track your next objective.</p>
    </div>

    <section class="max-w-xl mx-auto w-full">
        <form asp-action="Create" method="post" class="bg-card border border-border rounded-xl shadow-sm p-6 lg:p-8 space-y-6">
    @Html.AntiForgeryToken()

    <div class="space-y-2">
        <label asp-for="Title" class="text-sm font-medium text-foreground">Task Title</label>
        <input asp-for="Title" class="w-full px-3 py-2 border border-border rounded-md bg-card text-foreground placeholder:text-muted-foreground focus:ring-2 focus:ring-ring outline-none transition-all text-sm" placeholder="e.g. Weekly Sync" />
        <span asp-validation-for="Title" class="text-xs text-destructive"></span>
    </div>

    <div class="space-y-2">
        <label asp-for="Description" class="text-sm font-medium text-foreground">Description</label>
        <textarea asp-for="Description" class="w-full px-3 py-2 border border-border rounded-md bg-card text-foreground placeholder:text-muted-foreground focus:ring-2 focus:ring-ring outline-none transition-all text-sm resize-none" rows="4" placeholder="Describe the task..."></textarea>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="space-y-2">
            <label asp-for="DueDate" class="text-sm font-medium text-foreground">Due Date</label>
            <input asp-for="DueDate" type="date" class="w-full px-3 py-2 border border-border rounded-md bg-card text-foreground focus:ring-2 focus:ring-ring outline-none transition-all text-sm" />
            <span asp-validation-for="DueDate" class="text-xs text-destructive"></span>
        </div>
        <div class="space-y-2">
            <label asp-for="Priority" class="text-sm font-medium text-foreground">Priority</label>
            <select asp-for="Priority" asp-items="Model.PriorityOptions" class="w-full px-3 py-2 border border-border rounded-md bg-card text-foreground focus:ring-2 focus:ring-ring outline-none transition-all text-sm"></select>
        </div>
    </div>

    <div class="space-y-2">
        <label asp-for="RepetitionType" class="text-sm font-medium text-foreground">Repetition</label>
        <select asp-for="RepetitionType" asp-items="Model.RepetitionOptions" class="w-full px-3 py-2 border border-border rounded-md bg-card text-foreground focus:ring-2 focus:ring-ring outline-none transition-all text-sm"></select>
    </div>

    <div class="space-y-2">
        <input asp-for="TelegramChatId" type="hidden" id="create-chat-id" />
        <div class="text-xs text-muted-foreground" id="chat-id-hint">Using the default Telegram Chat ID from the Tasks page.</div>
    </div>

            <div class="pt-4 flex items-center justify-end gap-3 border-t border-border">
                <a class="px-4 py-2 text-sm font-medium text-muted-foreground hover:bg-secondary rounded-md transition-colors" asp-action="Index">Cancel</a>
                <button class="px-4 py-2 text-sm font-medium text-primary-foreground bg-primary rounded-md hover:opacity-90 shadow-sm transition-all active:scale-[0.98]" type="submit">Save Task</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
